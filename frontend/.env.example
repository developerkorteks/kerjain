# ── Development (default) ─────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=True
GO_API_URL=http://localhost:8080
SITE_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Production (salin ke .env dan sesuaikan) ──────────────────
# SECRET_KEY=buat-random-string-panjang-di-sini
# DEBUG=False
# GO_API_URL=http://127.0.0.1:8080        # kalau Go dan Django di server yang sama
# GO_API_URL=https://api.domain.com       # kalau Go di subdomain terpisah
# SITE_URL=https://domain.com
# ALLOWED_HOSTS=domain.com,www.domain.com
# BOARD_USER=admin
# BOARD_PASS=ganti-password-ini
# UMAMI_URL=https://analytics.domain.com/script.js
# UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
