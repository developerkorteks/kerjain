# ── Akun Instagram khusus bot (jangan pakai akun pribadi!) ──
IG_USERNAME=username_bot_kamu
IG_PASSWORD=password_bot_kamu

# ── Go API ──
GO_API_URL=http://localhost:60880
INGEST_API_KEY=isi_dari_env_INGEST_API_KEY_di_go

# ── Akun IG yang di-monitor (pisah koma, tanpa @) ──
IG_TARGET_ACCOUNTS=lokersmg,lokersemarang,lokermagang_smg

# ── Interval polling dalam detik (default 600 = 10 menit) ──
POLL_INTERVAL=600

# ── Berapa post terakhir yang dicek per akun per polling ──
POSTS_PER_ACCOUNT=12
